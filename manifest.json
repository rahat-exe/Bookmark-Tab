{
  "manifest_version": 3,
  "name": "Bookmark Tab",
  "version": "1.0.0",
  "description": "Replaces your new tab with a beautiful grid of all your bookmarks.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "favicon"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
